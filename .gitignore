*.onnx
*.safetensors
*.bin
*.pdparams
models/
weights/

# Pipeline outputs and rendered pages
/out
out/
*/results.json
*/manifest.json

# Layout parity golden (not shipped)
golden/
fixtures/

# Local ONNX Runtime shared libs
libonnxruntime*.so*

# Env / secrets
.env
*.env
logs/

# OmniDocBench (research-only dataset + cloned eval repo — never commit)
# Our repro scripts/configs/results live in bench/omnidocbench/ and ARE committed.
bench/OmniDocBench/
bench/omnidocbench/data/
bench/omnidocbench/preds/
bench/omnidocbench/work/
bench/omnidocbench/work_*/
bench/omnidocbench/*.parquet
bench/omnidocbench/scorer-venv/
# pipeline stdout logs echo recognized dataset text (license-encumbered) — scores-only .scorer.log/.json stay committed
bench/omnidocbench/results/*.run.log
**/OmniDocBench_*/
bench/omnidocbench/paddle-venv/
