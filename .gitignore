# Rust build
/target
**/*.rs.bk

# Model weights and graphs (download separately; see README)
*.onnx
*.safetensors
*.bin
*.pdparams
models/
weights/

# Pipeline outputs and rendered pages
/out
out/
*/results.json
*/manifest.json

# Layout parity golden (not shipped)
golden/
fixtures/

# Local ONNX Runtime shared libs
libonnxruntime*.so*

# Env / secrets
.env
*.env
logs/

# OmniDocBench (research-only dataset + cloned eval repo — never commit)
# Our repro scripts/configs/results live in bench/omnidocbench/ and ARE committed.
bench/OmniDocBench/
# data/ holds the dataset itself (never commit) — but the scorer configs under data/subsets/ are
# OURS and are the only way to reproduce a score, so re-include just those. Git cannot re-include a
# file whose parent DIRECTORY is excluded, hence `data/*` + a re-included `subsets/` rather than
# `data/`.
bench/omnidocbench/data/*
!bench/omnidocbench/data/subsets/
bench/omnidocbench/data/subsets/*
!bench/omnidocbench/data/subsets/*.yaml
bench/omnidocbench/preds/
bench/omnidocbench/work/
bench/omnidocbench/work_*/
bench/omnidocbench/*.parquet
bench/omnidocbench/scorer-venv/
# pipeline stdout logs echo recognized dataset text (license-encumbered) — scores-only .scorer.log/.json stay committed
bench/omnidocbench/results/*.run.log
**/OmniDocBench_*/
bench/omnidocbench/paddle-venv/
__pycache__/

# Ralph-loop agent scaffolding (prompts, checklists, loop runners). Kept on disk — the loop reads
# them — but not shipped: they are how the work was done, not part of the library. Untracked from the
# tip only; earlier commits still contain them (scrubbing history needs a fresh bundle + a
# force-push, which is a human call).
PROMPT_*.md
CHECKLIST_*.md
run_*.sh
